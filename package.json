{
  "name": "harborclient",
  "version": "1.5.7",
  "description": "A Postman-style HTTP client built with Electron",
  "main": "./out/main/index.js",
  "desktopName": "harborclient",
  "homepage": "https://harborclient.com/",
  "author": {
    "name": "Harbor",
    "email": "harbor@example.com"
  },
  "license": "MIT",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "build": "electron-vite build",
    "preview": "ELECTRON_DISABLE_SANDBOX=1 electron-vite preview",
    "postinstall": "node scripts/install-app-deps.mjs",
    "dist": "pnpm build && electron-builder",
    "test": "node scripts/test-with-native.mjs",
    "test:watch": "vitest",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config --local core.hooksPath .githooks 2>/dev/null || true",
    "release": "gh workflow run Release --ref main -f release_type=patch",
    "release:patch": "gh workflow run Release --ref main -f release_type=patch",
    "release:minor": "gh workflow run Release --ref main -f release_type=minor",
    "release:major": "gh workflow run Release --ref main -f release_type=major",
    "docs:build": "pnpm docs:build:nav && vitepress build docs",
    "docs:build:nav": "node scripts/sync-docs-assets.mjs && node scripts/build-docs-nav.mjs && node scripts/assert-docs-slugs.mjs",
    "docs:preview": "pnpm docs:build && vitepress preview docs",
    "docs:serve": "pnpm docs:build:nav && concurrently --kill-others --prefixColors=auto -n nav,vp \"node scripts/watch-docs-nav.mjs\" \"vitepress dev docs\"",
    "kill": "pkill -f \"harborclient/node_modules/.pnpm/electron\""
  },
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@lezer/highlight": "^1.2.3",
    "@reduxjs/toolkit": "^2.12.0",
    "@uiw/codemirror-themes-all": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "electron-window-state": "^5.0.3",
    "firebase": "^12.15.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.3.0",
    "undici": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^8.2.2",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.21",
    "debug": "^4.4.3",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.22.0",
    "mermaid": "^11.15.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
