{
  "name": "@harborclient/harborclient",
  "productName": "HarborClient",
  "version": "1.8.34",
  "description": "The free API client that keeps your work private: no accounts, no subscriptions, no lock-in.",
  "main": "./out/main/index.js",
  "desktopName": "harborclient",
  "homepage": "https://harborclient.com/",
  "author": {
    "name": "HarborClient",
    "email": "contact@harborclient.com"
  },
  "license": "MIT",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "build": "electron-vite build",
    "preview": "ELECTRON_DISABLE_SANDBOX=1 electron-vite preview",
    "postinstall": "node scripts/install-app-deps.mjs",
    "dist": "pnpm build && electron-builder",
    "dist:deb": "pnpm build && electron-builder --linux deb --publish never",
    "dist:linux": "pnpm build && electron-builder --linux --publish never",
    "test": "node scripts/test-with-native.mjs",
    "test:watch": "vitest",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config --local core.hooksPath .githooks 2>/dev/null || true",
    "release": "gh workflow run Release --ref main -f release_type=patch",
    "release:patch": "gh workflow run Release --ref main -f release_type=patch",
    "release:minor": "gh workflow run Release --ref main -f release_type=minor",
    "release:major": "gh workflow run Release --ref main -f release_type=major",
    "kill": "pkill -f \"harborclient/node_modules/.pnpm/electron\"",
    "screenshots": "node scripts/capture-screenshots.mjs"
  },
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@harborclient/http": "^0.1.1",
    "@harborclient/sdk": "^0.6.3",
    "@harborclient/team-hub-api": "^0.1.1",
    "@lezer/highlight": "^1.2.3",
    "@reduxjs/toolkit": "^2.12.0",
    "@uiw/codemirror-themes-all": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "@usebruno/filestore": "0.10.0",
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "electron-window-state": "^5.0.3",
    "esbuild": "^0.25.12",
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "isomorphic-git": "^1.38.5",
    "jmespath": "^0.16.0",
    "jszip": "^3.10.1",
    "minisearch": "^7.2.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "nanoid": "3.3.8",
    "openai": "^6.44.0",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "remark-gfm": "^4.0.1",
    "ses": "^2.2.0",
    "undici": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jmespath": "^0.15.2",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "debug": "^4.4.3",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.22.0",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@harborclient/sdk>@types/react": "$@types/react",
      "@harborclient/sdk>@types/react-dom": "$@types/react-dom"
    }
  }
}
