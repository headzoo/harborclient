{
  "name": "harborclient",
  "version": "1.2.1",
  "description": "A Postman-style HTTP client built with Electron",
  "main": "./out/main/index.js",
  "desktopName": "harborclient",
  "homepage": "https://harborclient.com/",
  "author": {
    "name": "Harbor",
    "email": "harbor@example.com"
  },
  "license": "MIT",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "build": "electron-vite build",
    "preview": "ELECTRON_DISABLE_SANDBOX=1 electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "pnpm build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "git config --local core.hooksPath .githooks 2>/dev/null || true",
    "release": "gh workflow run Release --ref main -f release_type=patch",
    "release:patch": "gh workflow run Release --ref main -f release_type=patch",
    "release:minor": "gh workflow run Release --ref main -f release_type=minor",
    "release:major": "gh workflow run Release --ref main -f release_type=major",
    "docs:build": "pnpm docs:build:nav && vitepress build docs",
    "docs:build:nav": "node scripts/sync-docs-assets.mjs && node scripts/build-docs-nav.mjs && node scripts/assert-docs-slugs.mjs",
    "docs:preview": "pnpm docs:build && vitepress preview docs",
    "docs:serve": "pnpm docs:build:nav && concurrently --kill-others --prefixColors=auto -n nav,vp \"node scripts/watch-docs-nav.mjs\" \"vitepress dev docs\""
  },
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@awesome.me/kit-55c528f18b": "^1.0.2",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^11.9.1",
    "electron-window-state": "^5.0.3",
    "isolated-vm": "^6.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^8.2.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "isolated-vm"
    ]
  }
}
